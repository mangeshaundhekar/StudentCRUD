@model IEnumerable<SimpleCrudDemo.Models.Student>

<h2>Student List</h2>
<a href="/Student/Create" class="btn btn-success">Add Student</a>
<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>ID</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Grade</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StudId</td>
                <td>@item.FirstName</td>
                <td>@item.LastName</td>
                <td>@item.Grade</td>
                <td>
                    @* <a href="/Student/Edit/@item.StudId" class="btn btn-warning btn-sm">Edit</a> *@
                    <a asp-action="Edit" asp-route-id="@item.StudId" class="btn btn-warning btn-sm">Edit</a>
                    <a href="/Student/Delete/@item.StudId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
