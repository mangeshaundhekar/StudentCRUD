@model SimpleCrudDemo.Models.Student

@{
    ViewData["Title"] = "Edit Student";
}

<h2>Edit Student</h2>

<form asp-action="Edit" method="post">
    <div class="form-group">
        <label>Roll No.</label>
        <input type="text" asp-for="StudId" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>First Name</label>
        <input type="text" asp-for="FirstName" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Last Name</label>
        <input type="text" asp-for="LastName" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Grade</label>
        <input type="text" asp-for="Grade" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary mt-2">Update</button>
    <a href="/Student/Index" class="btn btn-secondary mt-2">Cancel</a>
</form>
